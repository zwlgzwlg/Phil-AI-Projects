# Server port (optional — defaults to 3000)
PORT=3000

# Anthropic API key (optional — can also be set via the in-game UI).
# If set here, the key is loaded when the server starts.
# The key stays on the server and is never sent to the browser.
ANTHROPIC_API_KEY=

# OpenAI API key (optional — can also be set via the in-game UI).
# Same security model as above — key stays on the server.
OPENAI_API_KEY=
